# Copy to secrets.env (gitignored) and change the values for your local cluster.
# scripts/k8s_up.sh copies this file automatically if secrets.env is missing.
# Mirrors the Compose .env.example pattern: committed placeholders, real values stay untracked.
POSTGRES_PASSWORD=changeme
METASTORE_PASSWORD=changeme
AIRFLOW_PASSWORD=changeme
AIRFLOW_ADMIN_PASSWORD=changeme
